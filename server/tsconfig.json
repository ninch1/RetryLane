{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "esModuleInterop": true,
    "verbatimModuleSyntax": false,

    "skipLibCheck": true
  },
  "include": ["src"]
}
